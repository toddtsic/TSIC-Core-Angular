                                                        <Value>100000</Value>
                                                      </CustomProperty>
                                                      <CustomProperty>
                                                        <Name>MaxColumnCount</Name>
                                                        <Value>20</Value>
                                                      </CustomProperty>
                                                    </CustomProperties>
                                                    <DataSetName>MainReportData</DataSetName>
                                                    <TablixBody>
                                                      <TablixColumns>
                                                        <TablixColumn><Width>22pt</Width></TablixColumn>
                                                        <TablixColumn><Width>100pt</Width></TablixColumn>
                                                        <TablixColumn><Width>38pt</Width></TablixColumn>
                                                        <TablixColumn><Width>26pt</Width></TablixColumn>
                                                        <TablixColumn><Width>22pt</Width></TablixColumn>
                                                        <TablixColumn><Width>63pt</Width></TablixColumn>
                                                      </TablixColumns>
                                                      <TablixRows>
                                                        <TablixRow>
                                                          <Height>11pt</Height>
                                                          <TablixCells>
                                                            <TablixCell>
                                                              <CellContents>
                                                                <Textbox Name="iUniform">
                                                                  <Left>0pt</Left><Top>0pt</Top><Height>11pt</Height><Width>22pt</Width>
                                                                  <Style>
                                                                    <FontFamily>Arial</FontFamily>
                                                                    <PaddingLeft>1pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>1pt</PaddingTop><PaddingBottom>1pt</PaddingBottom>
                                                                    <TopBorder><Style>None</Style></TopBorder>
                                                                    <LeftBorder><Style>None</Style></LeftBorder>
                                                                    <RightBorder><Style>None</Style></RightBorder>
                                                                    <BottomBorder>
                                                                      <Color>Black</Color>
                                                                      <Style>=IIf(Fields!isLastRow.Value = 1, "None", "Solid")</Style>
                                                                      <Width>1pt</Width>
                                                                    </BottomBorder>
                                                                  </Style>
                                                                  <CanGrow>false</CanGrow>
                                                                  <Paragraphs>
                                                                    <Paragraph>
                                                                      <TextRuns>
                                                                        <TextRun>
                                                                          <Value>=Fields!uniform_no.Value</Value>
                                                                          <Style><FontFamily>Arial</FontFamily><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight><Color>#000000</Color></Style>
                                                                        </TextRun>
                                                                      </TextRuns>
                                                                      <Style><FontFamily>Arial</FontFamily><TextAlign>Right</TextAlign></Style>
                                                                    </Paragraph>
                                                                  </Paragraphs>
                                                                </Textbox>
                                                                <RowSpan>1</RowSpan><ColSpan>1</ColSpan>
                                                              </CellContents>
                                                            </TablixCell>
                                                            <TablixCell>
                                                              <CellContents>
                                                                <Textbox Name="iName">
                                                                  <Left>0pt</Left><Top>0pt</Top><Height>11pt</Height><Width>100pt</Width>
                                                                  <Style>
                                                                    <FontFamily>Arial</FontFamily>
                                                                    <PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>1pt</PaddingTop><PaddingBottom>1pt</PaddingBottom>
                                                                    <TopBorder><Style>None</Style></TopBorder>
                                                                    <LeftBorder><Style>None</Style></LeftBorder>
                                                                    <RightBorder><Style>None</Style></RightBorder>
                                                                    <BottomBorder>
                                                                      <Color>Black</Color>
                                                                      <Style>=IIf(Fields!isLastRow.Value = 1, "None", "Solid")</Style>
                                                                      <Width>1pt</Width>
                                                                    </BottomBorder>
                                                                  </Style>
                                                                  <CanGrow>false</CanGrow>
                                                                  <Paragraphs>
                                                                    <Paragraph>
                                                                      <TextRuns>
                                                                        <TextRun>
                                                                          <Value>=Fields!player.Value</Value>
                                                                          <Style><FontFamily>Arial</FontFamily><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight><Color>#000000</Color></Style>
                                                                        </TextRun>
                                                                      </TextRuns>
                                                                      <Style><FontFamily>Arial</FontFamily></Style>
                                                                    </Paragraph>
                                                                  </Paragraphs>
                                                                </Textbox>
                                                                <RowSpan>1</RowSpan><ColSpan>1</ColSpan>
                                                              </CellContents>
                                                            </TablixCell>
                                                            <TablixCell>
                                                              <CellContents>
                                                                <Textbox Name="iPosition">
                                                                  <Left>0pt</Left><Top>0pt</Top><Height>11pt</Height><Width>38pt</Width>
                                                                  <Style>
                                                                    <FontFamily>Arial</FontFamily>
                                                                    <PaddingLeft>1pt</PaddingLeft><PaddingRight>1pt</PaddingRight><PaddingTop>1pt</PaddingTop><PaddingBottom>1pt</PaddingBottom>
                                                                    <TopBorder><Style>None</Style></TopBorder>
                                                                    <LeftBorder><Style>None</Style></LeftBorder>
                                                                    <RightBorder><Style>None</Style></RightBorder>
                                                                    <BottomBorder>
                                                                      <Color>Black</Color>
                                                                      <Style>=IIf(Fields!isLastRow.Value = 1, "None", "Solid")</Style>
                                                                      <Width>1pt</Width>
                                                                    </BottomBorder>
                                                                  </Style>
                                                                  <CanGrow>false</CanGrow>
                                                                  <Paragraphs>
                                                                    <Paragraph>
                                                                      <TextRuns>
                                                                        <TextRun>
                                                                          <Value>=Fields!position.Value</Value>
                                                                          <Style><FontFamily>Arial</FontFamily><FontSize>6.5pt</FontSize><Color>#000000</Color></Style>
                                                                        </TextRun>
                                                                      </TextRuns>
                                                                      <Style><FontFamily>Arial</FontFamily></Style>
                                                                    </Paragraph>
                                                                  </Paragraphs>
                                                                </Textbox>
                                                                <RowSpan>1</RowSpan><ColSpan>1</ColSpan>
                                                              </CellContents>
                                                            </TablixCell>
                                                            <TablixCell>
                                                              <CellContents>
                                                                <Textbox Name="iGradYear">
                                                                  <Left>0pt</Left><Top>0pt</Top><Height>11pt</Height><Width>26pt</Width>
                                                                  <Style>
                                                                    <FontFamily>Arial</FontFamily>
                                                                    <PaddingLeft>1pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>1pt</PaddingTop><PaddingBottom>1pt</PaddingBottom>
                                                                    <TopBorder><Style>None</Style></TopBorder>
                                                                    <LeftBorder><Style>None</Style></LeftBorder>
                                                                    <RightBorder><Style>None</Style></RightBorder>
                                                                    <BottomBorder>
                                                                      <Color>Black</Color>
                                                                      <Style>=IIf(Fields!isLastRow.Value = 1, "None", "Solid")</Style>
                                                                      <Width>1pt</Width>
                                                                    </BottomBorder>
                                                                  </Style>
                                                                  <CanGrow>false</CanGrow>
                                                                  <Paragraphs>
                                                                    <Paragraph>
                                                                      <TextRuns>
                                                                        <TextRun>
                                                                          <Value>=Fields!gradYear.Value</Value>
                                                                          <Style><FontFamily>Arial</FontFamily><FontSize>6.5pt</FontSize><Color>#000000</Color></Style>
                                                                        </TextRun>
                                                                      </TextRuns>
                                                                      <Style><FontFamily>Arial</FontFamily><TextAlign>Center</TextAlign></Style>
                                                                    </Paragraph>
                                                                  </Paragraphs>
                                                                </Textbox>
                                                                <RowSpan>1</RowSpan><ColSpan>1</ColSpan>
                                                              </CellContents>
                                                            </TablixCell>
                                                            <TablixCell>
                                                              <CellContents>
                                                                <Textbox Name="iGpa">
                                                                  <Left>0pt</Left><Top>0pt</Top><Height>11pt</Height><Width>22pt</Width>
                                                                  <Style>
                                                                    <FontFamily>Arial</FontFamily>
                                                                    <PaddingLeft>1pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>1pt</PaddingTop><PaddingBottom>1pt</PaddingBottom>
                                                                    <TopBorder><Style>None</Style></TopBorder>
                                                                    <LeftBorder><Style>None</Style></LeftBorder>
                                                                    <RightBorder><Style>None</Style></RightBorder>
                                                                    <BottomBorder>
                                                                      <Color>Black</Color>
                                                                      <Style>=IIf(Fields!isLastRow.Value = 1, "None", "Solid")</Style>
                                                                      <Width>1pt</Width>
                                                                    </BottomBorder>
                                                                  </Style>
                                                                  <CanGrow>false</CanGrow>
                                                                  <Paragraphs>
                                                                    <Paragraph>
                                                                      <TextRuns>
                                                                        <TextRun>
                                                                          <Value>=IIf(Fields!bCollegeCommit.Value = "yes", "", Fields!gpa.Value)</Value>
                                                                          <Style><FontFamily>Arial</FontFamily><FontSize>6.5pt</FontSize><Color>#000000</Color></Style>
                                                                        </TextRun>
                                                                      </TextRuns>
                                                                      <Style><FontFamily>Arial</FontFamily><TextAlign>Center</TextAlign></Style>
                                                                    </Paragraph>
                                                                  </Paragraphs>
                                                                </Textbox>
                                                                <RowSpan>1</RowSpan><ColSpan>1</ColSpan>
                                                              </CellContents>
                                                            </TablixCell>
                                                            <TablixCell>
                                                              <CellContents>
                                                                <Textbox Name="iCollegeCommit">
                                                                  <Left>0pt</Left><Top>0pt</Top><Height>11pt</Height><Width>63pt</Width>
                                                                  <Style>
                                                                    <FontFamily>Arial</FontFamily>
                                                                    <PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>1pt</PaddingTop><PaddingBottom>1pt</PaddingBottom>
                                                                    <TopBorder><Style>None</Style></TopBorder>
                                                                    <LeftBorder><Style>None</Style></LeftBorder>
                                                                    <RightBorder><Style>None</Style></RightBorder>
                                                                    <BottomBorder>
                                                                      <Color>Black</Color>
                                                                      <Style>=IIf(Fields!isLastRow.Value = 1, "None", "Solid")</Style>
                                                                      <Width>1pt</Width>
                                                                    </BottomBorder>
                                                                  </Style>
                                                                  <CanGrow>false</CanGrow>
                                                                  <Paragraphs>
                                                                    <Paragraph>
                                                                      <TextRuns>
                                                                        <TextRun>
                                                                          <Value>=Left(IIf(IsNothing(Fields!collegeCommit.Value), "", Fields!collegeCommit.Value), 22)</Value>
                                                                          <Style><FontFamily>Arial</FontFamily><FontSize>6.5pt</FontSize><Color>#000000</Color></Style>
                                                                        </TextRun>
                                                                      </TextRuns>
                                                                      <Style><FontFamily>Arial</FontFamily><TextAlign>Right</TextAlign></Style>
                                                                    </Paragraph>
                                                                  </Paragraphs>
                                                                </Textbox>
                                                                <RowSpan>1</RowSpan><ColSpan>1</ColSpan>
                                                              </CellContents>
                                                            </TablixCell>
                                                          </TablixCells>
                                                        </TablixRow>
                                                      </TablixRows>
                                                    </TablixBody>
                                                    <TablixColumnHierarchy>
                                                      <TablixMembers>
                                                        <TablixMember />
                                                        <TablixMember />
                                                        <TablixMember />
                                                        <TablixMember />
                                                        <TablixMember />
                                                        <TablixMember />
                                                      </TablixMembers>
                                                    </TablixColumnHierarchy>
                                                    <TablixRowHierarchy>
                                                      <TablixMembers>
                                                        <TablixMember>
                                                          <Group Name="innerDetail">
                                                            <GroupExpressions>
                                                              <GroupExpression>=Fields!teamID.Value.ToString() + "|" + Fields!player.Value + "|" + IIf(IsNothing(Fields!uniform_no.Value), "", Fields!uniform_no.Value)</GroupExpression>
                                                            </GroupExpressions>
                                                            <Filters>
                                                              <Filter>
                                                                <FilterExpression>=Fields!roleName.Value</FilterExpression>
                                                                <Operator>Equal</Operator>
                                                                <FilterValues>
                                                                  <FilterValue>Player</FilterValue>
                                                                </FilterValues>
                                                              </Filter>
                                                            </Filters>
                                                          </Group>
                                                        </TablixMember>
                                                      </TablixMembers>
                                                    </TablixRowHierarchy>
                                                  </Tablix>
                                                  <Textbox Name="cardAnchor">
                                                    <Left>0pt</Left>
                                                    <Top>312pt</Top>
                                                    <Height>1pt</Height>
                                                    <Width>1pt</Width>
                                                    <Style>
                                                      <Border><Style>None</Style></Border>
                                                    </Style>
                                                    <CanGrow>false</CanGrow>
                                                    <Paragraphs>
                                                      <Paragraph>
                                                        <TextRuns>
                                                          <TextRun>
                                                            <Value></Value>
                                                            <Style />
                                                          </TextRun>
                                                        </TextRuns>
                                                        <Style />
                                                      </Paragraph>
                                                    </Paragraphs>
                                                  </Textbox>
                                                </ReportItems>
                                              </Rectangle>
                                              <Textbox Name="cellAnchor">
                                                <Left>0pt</Left>
                                                <Top>318pt</Top>
                                                <Height>1pt</Height>
                                                <Width>1pt</Width>
                                                <Style>
                                                  <Border><Style>None</Style></Border>
                                                </Style>
                                                <CanGrow>false</CanGrow>
                                                <Paragraphs>
                                                  <Paragraph>
                                                    <TextRuns>
                                                      <TextRun>
                                                        <Value></Value>
                                                        <Style />
                                                      </TextRun>
                                                    </TextRuns>
                                                    <Style />
                                                  </Paragraph>
                                                </Paragraphs>
                                              </Textbox>
                                            </ReportItems>
                                          </Rectangle>
                                          <RowSpan>1</RowSpan>
                                          <ColSpan>1</ColSpan>
                                        </CellContents>
                                      </TablixCell>
                                    </TablixCells>
                                  </TablixRow>
                                </TablixRows>
                              </TablixBody>
                              <TablixColumnHierarchy>
                                <TablixMembers>
                                  <TablixMember />
                                </TablixMembers>
                              </TablixColumnHierarchy>
                              <TablixRowHierarchy>
                                <TablixMembers>
                                  <TablixMember>
                                    <Group Name="DivisionGroup">
                                      <GroupExpressions>
                                        <GroupExpression>=Fields!agDiv.Value</GroupExpression>
                                      </GroupExpressions>
                                      <PageBreak>
                                        <BreakLocation>Between</BreakLocation>
                                        <ResetPageNumber>true</ResetPageNumber>
                                      </PageBreak>
                                    </Group>
                                    <SortExpressions>
                                      <SortExpression>
                                        <Value>=Fields!agDiv.Value</Value>
                                        <Direction>Ascending</Direction>
                                      </SortExpression>
                                    </SortExpressions>
                                    <TablixMembers>
                                      <TablixMember>
                                        <KeepWithGroup>After</KeepWithGroup>
                                        <RepeatOnNewPage>true</RepeatOnNewPage>
                                      </TablixMember>
                                      <TablixMember>
                                        <Group Name="MatrixRow">
                                          <GroupExpressions>
                                            <GroupExpression>=Fields!divTeamRow.Value</GroupExpression>
                                          </GroupExpressions>
                                        </Group>
                                        <SortExpressions>
                                          <SortExpression>
                                            <Value>=Fields!divTeamRow.Value</Value>
                                            <Direction>Ascending</Direction>
                                          </SortExpression>
                                        </SortExpressions>
                                      </TablixMember>
                                    </TablixMembers>
                                  </TablixMember>
                                </TablixMembers>
                              </TablixRowHierarchy>
                            </Tablix>
        </ReportItems>
        <Style>
          <FontFamily>Arial</FontFamily>
          <Border><Style>None</Style></Border>
        </Style>
      </Body>
      <Width>277pt</Width>
      <Page>
        <PageHeader>
          <Height>6pt</Height>
          <PrintOnFirstPage>true</PrintOnFirstPage>
          <PrintOnLastPage>true</PrintOnLastPage>
          <Style>
            <FontFamily>Arial</FontFamily>
            <Border><Style>None</Style></Border>
          </Style>
        </PageHeader>
        <PageFooter>
          <Height>22pt</Height>
          <PrintOnFirstPage>true</PrintOnFirstPage>
          <PrintOnLastPage>true</PrintOnLastPage>
          <ReportItems>
            <Textbox Name="txtFooterBranding">
              <Left>0pt</Left>
              <Top>4pt</Top>
              <Height>14pt</Height>
              <Width>460pt</Width>
              <Style>
                <FontFamily>Arial</FontFamily>
                <PaddingLeft>2pt</PaddingLeft>
                <PaddingRight>2pt</PaddingRight>
                <PaddingTop>2pt</PaddingTop>
                <PaddingBottom>2pt</PaddingBottom>
                <Border><Style>None</Style></Border>
              </Style>
              <CanGrow>true</CanGrow>
              <KeepTogether>true</KeepTogether>
              <Paragraphs>
                <Paragraph>
                  <TextRuns>
                    <TextRun>
                      <Value>Reports By TeamSportsInfo.com</Value>
                      <Style>
                        <FontFamily>Arial</FontFamily>
                        <FontSize>7pt</FontSize>
                        <Color>#666666</Color>
                      </Style>
                    </TextRun>
                  </TextRuns>
                  <Style>
                    <FontFamily>Arial</FontFamily>
                  </Style>
                </Paragraph>
              </Paragraphs>
            </Textbox>
            <Textbox Name="txtFooterPageNum">
              <Left>464pt</Left>
              <Top>4pt</Top>
              <Height>14pt</Height>
              <Width>90pt</Width>
              <Style>
