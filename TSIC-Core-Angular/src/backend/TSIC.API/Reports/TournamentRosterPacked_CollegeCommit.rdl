                                                </Paragraphs>
                                              </Textbox>
                                              <Rectangle Name="cardOuter">
                                                <Left>3pt</Left>
                                                <Top>3pt</Top>
                                                <Height>314pt</Height>
                                                <Width>271pt</Width>
                                                <Style>
                                                  <FontFamily>Arial</FontFamily>
                                                  <Border>
                                                    <Color>Black</Color>
                                                    <Style>Solid</Style>
                                                    <Width>0.75pt</Width>
                                                  </Border>
                                                </Style>
                                                <ReportItems>
                                                  <Textbox Name="txtTeamHeader">
                                                    <Left>0pt</Left>
                                                    <Top>0pt</Top>
                                                    <Height>14pt</Height>
                                                    <Width>271pt</Width>
                                                    <Style>
                                                      <FontFamily>Arial</FontFamily>
                                                      <TextAlign>Center</TextAlign>
                                                      <VerticalAlign>Middle</VerticalAlign>
                                                      <PaddingLeft>0pt</PaddingLeft>
                                                      <PaddingRight>0pt</PaddingRight>
                                                      <PaddingTop>0pt</PaddingTop>
                                                      <PaddingBottom>0pt</PaddingBottom>
                                                      <Border><Style>None</Style></Border>
                                                    </Style>
