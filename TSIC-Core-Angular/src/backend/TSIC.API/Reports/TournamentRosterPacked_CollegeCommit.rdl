                                                    <KeepTogether>true</KeepTogether>
                                                    <Paragraphs>
                                                      <Paragraph>
                                                        <TextRuns>
                                                          <TextRun>
                                                            <Value>=First(Fields!clubTeamName.Value)</Value>
                                                            <Style>
                                                              <FontFamily>Arial</FontFamily>
                                                              <FontSize>8pt</FontSize>
                                                              <FontWeight>Bold</FontWeight>
                                                              <Color>#000000</Color>
                                                            </Style>
                                                          </TextRun>
                                                        </TextRuns>
                                                        <Style>
                                                          <TextAlign>Center</TextAlign>
                                                        </Style>
                                                      </Paragraph>
                                                    </Paragraphs>
                                                  </Textbox>
                                                  <Textbox Name="txtTeamRepLine">
                                                    <Left>0pt</Left>
                                                    <Top>14pt</Top>
                                                    <Height>12pt</Height>
                                                    <Width>271pt</Width>
                                                    <Style>
                                                      <FontFamily>Arial</FontFamily>
                                                      <TextAlign>Center</TextAlign>
                                                      <VerticalAlign>Middle</VerticalAlign>
                                                      <PaddingLeft>2pt</PaddingLeft>
                                                      <PaddingRight>2pt</PaddingRight>
                                                      <PaddingTop>0pt</PaddingTop>
                                                      <PaddingBottom>0pt</PaddingBottom>
                                                      <Border><Style>None</Style></Border>
                                                    </Style>
                                                    <CanGrow>false</CanGrow>
                                                    <KeepTogether>true</KeepTogether>
                                                    <Paragraphs>
                                                      <Paragraph>
                                                        <TextRuns>
                                                          <TextRun>
                                                            <Value>=Trim(First(Fields!clubRepName.Value) + " " + First(Fields!clubRepEmail.Value) + " " + First(Fields!clubRepCellphone.Value))</Value>
                                                            <Style>
                                                              <FontFamily>Arial</FontFamily>
                                                              <FontSize>6.5pt</FontSize>
                                                              <Color>#000000</Color>
                                                            </Style>
                                                          </TextRun>
                                                        </TextRuns>
                                                        <Style>
                                                          <TextAlign>Center</TextAlign>
                                                        </Style>
                                                      </Paragraph>
                                                    </Paragraphs>
                                                  </Textbox>
                                                  <Line Name="titleUnderline">
