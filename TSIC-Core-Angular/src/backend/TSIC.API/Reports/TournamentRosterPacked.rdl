                                                          <Group Name="innerDetail">
                                                            <GroupExpressions>
                                                              <GroupExpression>=Fields!teamID.Value.ToString() + "|" + Fields!player.Value + "|" + CStr(Fields!roleSort.Value) + "|" + IIf(IsNothing(Fields!uniform_no.Value), "", Fields!uniform_no.Value)</GroupExpression>
