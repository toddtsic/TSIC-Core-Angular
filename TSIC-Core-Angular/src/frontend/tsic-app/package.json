    "express": "4.18.2",
    "qrcode": "^1.5.4",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
