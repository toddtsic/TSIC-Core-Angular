    "@angular/forms": "22.0.0",
    "@angular/localize": "^22.0.0",
    "@angular/platform-browser": "22.0.0",
    "@angular/platform-browser-dynamic": "22.0.0",
    "@angular/platform-server": "22.0.0",
    "@angular/router": "^22.0.0",
    "@syncfusion/ej2-angular-buttons": "33.1.44",
    "@syncfusion/ej2-angular-charts": "33.1.44",
    "@syncfusion/ej2-angular-diagrams": "33.1.44",
    "@syncfusion/ej2-angular-dropdowns": "33.1.44",
    "@syncfusion/ej2-angular-grids": "33.1.44",
    "@syncfusion/ej2-angular-inputs": "33.1.44",
