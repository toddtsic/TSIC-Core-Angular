{
  "name": "tsic-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:tsic-app": "node dist/tsic-app/server/server.mjs",
    "generate:api": "npx openapi-typescript-codegen --input http://localhost:5022/swagger/v1/swagger.json --output ./src/app/core/api --client fetch --useOptions false --exportCore false --exportServices false --exportModels true --exportSchemas false"
  },
  "private": true,
