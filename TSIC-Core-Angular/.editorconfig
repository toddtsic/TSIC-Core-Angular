# EditorConfig — TSIC Backend
# Suppress SonarQube style suggestions that produce build noise
# without indicating real bugs. Keep nullable (CS86xx) and
# security-relevant rules at their defaults.

root = false

[*.cs]

# ── LINQ style preferences (use Find/Exists/TrueForAll vs extension) ──
dotnet_diagnostic.S6602.severity = none   # Use Find instead of FirstOrDefault
dotnet_diagnostic.S6603.severity = none   # Use TrueForAll instead of All
dotnet_diagnostic.S6605.severity = none   # Use Exists instead of Any
dotnet_diagnostic.S3267.severity = none   # Simplify loop with LINQ Select/Where

# ── Code style noise ──
dotnet_diagnostic.S1066.severity = none   # Merge nested if statements
dotnet_diagnostic.S1075.severity = none   # Hardcoded URI
dotnet_diagnostic.S1135.severity = none   # Complete TODO comments
dotnet_diagnostic.S1199.severity = none   # Extract nested code block
dotnet_diagnostic.S1871.severity = none   # Duplicate switch/if branches
dotnet_diagnostic.S1905.severity = none   # Unnecessary cast
dotnet_diagnostic.S2325.severity = none   # Make method static
dotnet_diagnostic.S2589.severity = none   # Unnecessary null check
dotnet_diagnostic.S3251.severity = none   # Partial method without implementation (EF scaffold)
dotnet_diagnostic.S3358.severity = none   # Nested ternary
dotnet_diagnostic.S3923.severity = none   # Conditional returns same value
dotnet_diagnostic.S4136.severity = none   # Method overloads not adjacent
dotnet_diagnostic.S4144.severity = none   # Duplicate method implementations
dotnet_diagnostic.S6580.severity = none   # Format provider for date parsing
dotnet_diagnostic.S6960.severity = none   # Controller multiple responsibilities
dotnet_diagnostic.S6964.severity = none   # Value type not nullable/required
dotnet_diagnostic.S101.severity  = none   # Class naming (scaffolded entities)
dotnet_diagnostic.S125.severity  = none   # Commented-out code
dotnet_diagnostic.S927.severity  = none   # Parameter name mismatch with interface
dotnet_diagnostic.S1125.severity = none   # Unnecessary boolean literal
dotnet_diagnostic.S1172.severity = none   # Unused method parameter
dotnet_diagnostic.S1450.severity = none   # Field should be local variable
dotnet_diagnostic.S1862.severity = none   # Duplicate branch
dotnet_diagnostic.S2139.severity = none   # Log and rethrow
dotnet_diagnostic.S4487.severity = none   # Unread private field
dotnet_diagnostic.S4581.severity = none   # Guid instantiation
dotnet_diagnostic.S6562.severity = none   # DateTimeKind on new DateTime
dotnet_diagnostic.S6610.severity = none   # StartsWith char overload
